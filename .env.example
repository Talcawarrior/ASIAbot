# ASIAbot Configuration
# Copy this file to .env and fill in your values

# Bot mode (true = paper trading, false = live)
DRY_RUN=true

# Portfolio
INITIAL_PORTFOLIO=1000.0
SCAN_INTERVAL=300
SETTLEMENT_INTERVAL=120
SIA_INTERVAL=86400

# Risk limits
MAX_EXPOSURE_PCT=0.25
MAX_BET_PCT=0.03
KELLY_FRACTION=0.15
CITY_CAP=4

# Server
HOST=127.0.0.1
PORT=8091

# API Authentication
# Set ASIABOT_API_KEY to enable X-API-Key header auth on POST endpoints.
# If not set, the API runs in OPEN MODE (no auth — localhost dev only).
# Generate a strong key, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
ASIABOT_API_KEY=

# LLM (ZhipuAI / GLM)
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
LLM_MODEL=glm-4.5-flash

# ResolvedMarkets (orderbook depth)
RESOLVEDMARKETS_API_KEY=your_resolvedmarkets_api_key_here

# Polymarket (live trading only, DRY_RUN=false)
# POLY_PRIVATE_KEY=
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=

# Optional: Weather APIs
# WEATHERAPI_KEY=
