[MASTER]
# Pylint configuration for ASIAbot.
# Focus on real bugs (errors, warnings) rather than style nitpicks,
# since the codebase already enforces style via ruff.

# Ignore tests, scripts, and the Next.js dashboard source.
ignore-paths=^tests/,^scripts/,^src/,^node_modules/,^dashboard/,^\.next/,^out/,^htmlcov/

# Minimum Python version.
py-version=3.12

[FORMAT]
# Match ruff's line-length setting.
max-line-length=120

[MESSAGES CONTROL]
disable=C0301,C0302,C0114,C0115,C0116,C0103,C0206,C0325,C0411,C0412,C0413,C0415,W0511,W0404,W0406,W0603,W0611,W0612,W0613,W0212,W0102,W0104,W0107,W0621,W0707,W0718,W1203,W1404,W1510,E1101,E0401,R0801,R0401,R0901,R0902,R0903,R0904,R0911,R0912,R0913,R0914,R0915,R0916,R0917,R1702,R1704,R1705,R1710,R1714,R1715,R1716,R1718,R1720,R1721,R1722,R1723,R1724,R1725,R1728,R1729,R1730,R1731,R1732,R1733,R1734,R1735,R1736

[REPORTS]
# Show only errors and warnings, no refactor/style messages.
msg-template={path}:{line}:{column}: {symbol} ({msg_id}) {msg}
output-format=colorized
score=no
